# =============================================================================
# django-backend-template — environment configuration
# Copy to .env and fill in what you need. EVERYTHING optional below can be left
# blank; the backend boots and runs fine without it.
# =============================================================================

# --- Core (recommended to set) ----------------------------------------------
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*
# Comma-separated, e.g. https://app.example.com,https://admin.example.com
CSRF_TRUSTED_ORIGINS=

# --- Database (REQUIRED — Postgres/Neon only, no sqlite) --------------------
# The app refuses to start without this. Use a Neon branch for local dev too.
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require
DB_SSL_REQUIRE=False

# --- API metadata (shown in Swagger/OpenAPI) --------------------------------
API_TITLE=Backend API
API_DESCRIPTION=API built from the django-backend-template.
API_VERSION=1.0.0

# --- Auth / JWT -------------------------------------------------------------
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=30

# --- CORS -------------------------------------------------------------------
CORS_ALLOW_ALL_ORIGINS=True
# CORS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:5173

# --- Pagination / throttling ------------------------------------------------
PAGE_SIZE=30
THROTTLE_ANON=60/min
THROTTLE_USER=240/min

# =============================================================================
# OPTIONAL INTEGRATIONS — set to enable, leave blank to disable
# =============================================================================

# --- Sentry (error tracking) — enable by setting SENTRY_DSN ------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_PII=False

# --- Backblaze B2 (S3-compatible file storage) ------------------------------
# Set ALL four to route uploads/downloads to B2; otherwise files stay local.
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT_URL=            # e.g. https://s3.eu-central-003.backblazeb2.com
B2_REGION=                  # e.g. eu-central-003

# --- Redis (cache) — set REDIS_URL to enable; otherwise in-memory cache ------
REDIS_URL=                  # e.g. redis://default:pass@host:6379/0

# --- Celery (background tasks) — uses REDIS_URL unless overridden ------------
CELERY_BROKER_URL=
# Run tasks inline (no worker) during local dev:
CELERY_TASK_ALWAYS_EAGER=False

# --- Admin branding ---------------------------------------------------------
ADMIN_SITE_TITLE=Backend Admin
ADMIN_SITE_HEADER=Backend Admin
ADMIN_SITE_BRAND=Backend

# --- Deployment (Dokploy / Traefik on a VPS) --------------------------------
# DOMAIN: the hostname Traefik routes to and issues a Let's Encrypt cert for.
DOMAIN=api.example.com
# Gunicorn tuning (optional).
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
